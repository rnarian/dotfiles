export GOPATH=~/go

# PATH environment variable for use with MacPorts.
export PATH=/usr/local/bin:/usr/bin:/usr/local/heroku/bin:/usr/local/mysql/bin:/opt/local/bin:/opt/local/sbin:$PATH:$GOPATH/bin

PATH=/Applications/MAMP/bin/php/php7.2.1/bin:$PATH

export ANDROID_HOME=/usr/local/Cellar/android-sdk/24.4.1_1/
export PATH=$ANDROID_HOME:$PATH

# ⌘c/⌘v from https://github.com/mathiasbynens/dotfiles

# Make vim the default editor
export EDITOR="vim"

# Don’t clear the screen after quitting a manual page
export MANPAGER="less -X"

# Highlight section titles in manual pages
export LESS_TERMCAP_md="$PURPLE"

# Larger bash history (allow 32³ entries; default is 500)
export HISTSIZE=32768
export HISTFILESIZE=$HISTSIZE
export HISTCONTROL=ignoredups

# Make some commands not show up in history
export HISTIGNORE="ls:ls *:cd:cd -:pwd;exit:date:* --help"

# Update locale
export LANG="de_DE.UTF-8"

# Tiny Care Terminal

export TTC_REPOS="/Users/MAC-Layout/Dashbrew/public/snapaddy.dev,/Users/MAC-Layout/Server"
export TTC_SAY_BOX="bunny"
export TTC_WEATHER="Würzburg, Germany"
export TTC_APIKEYS="false"
